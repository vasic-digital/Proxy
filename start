#!/usr/bin/env bash
#######################################
# Proxy Service Start Script
# Starts all proxy services with VPN support
#######################################

set -euo pipefail

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/container-runtime.sh"

#######################################
# Show usage information
#######################################
usage() {
    cat << EOF
Usage: $(basename "$0") [OPTIONS]

Start Proxy service with caching and VPN routing.

Options:
    -h, --help          Show this help message
    -v, --verbose       Enable verbose output
    -p, --pull          Pull latest images before starting
    -n, --no-vpn        Start without VPN (standalone mode)
    --host-vpn          Use host network mode (routes through host's VPN)
    -s, --status        Show status after starting
    -d, --dry-run       Show what would be done without executing

Modes:
    Default (USE_VPN=true in .env)  - Containerized VPN
    Default (USE_VPN=false)         - Bridge network, no VPN
    --host-vpn                      - Uses host network (host VPN passes through)
    --no-vpn                        - Forces no VPN mode

Examples:
    $(basename "$0")              Start with config from .env
    $(basename "$0") --host-vpn   Start with host network (use host's VPN)
    $(basename "$0") --no-vpn     Start without VPN
    $(basename "$0") -pvs         Pull, start verbose, show status
EOF
}

#######################################
# Pull latest container images
#######################################
pull_images() {
    log "info" "Pulling latest container images..."
    
    local images=(
        "ubuntu/squid:latest"
        "vimagick/dante:latest"
        "dperson/openvpn-client:latest"
        "ghcr.io/caddyserver/caddy:latest"
    )
    
    for image in "${images[@]}"; do
        log "debug" "Pulling $image..."
        case "$CONTAINER_RUNTIME" in
            podman)
                podman pull "$image" 2>/dev/null || log "warn" "Failed to pull $image"
                ;;
            docker)
                docker pull "$image" 2>/dev/null || log "warn" "Failed to pull $image"
                ;;
        esac
    done
    
    log "info" "Image pull complete"
}

#######################################
# Check if services are already running
#######################################
check_running() {
    local running=false
    
    if is_container_running "proxy-squid"; then
        log "warn" "Squid proxy already running"
        running=true
    fi
    
    if is_container_running "proxy-dante"; then
        log "warn" "Dante SOCKS proxy already running"
        running=true
    fi
    
    if is_container_running "proxy-vpn"; then
        log "warn" "VPN container already running"
        running=true
    fi
    
    if [[ "$running" == "true" ]]; then
        log "info" "Use './stop' to stop services first, or './restart' to restart"
        return 1
    fi
    
    return 0
}

#######################################
# Start services with profile
# Arguments:
#   $1 - Profile name (vpn, host-vpn, no-vpn)
#######################################
start_with_profile() {
    local profile="$1"
    
    log "info" "Starting services with profile: $profile"
    
    case "$profile" in
        vpn)
            if [[ "$CONTAINER_RUNTIME" == "docker" ]]; then
                $COMPOSE_CMD --profile vpn --profile docker up -d
            else
                $COMPOSE_CMD --profile vpn up -d
            fi
            ;;
        host-vpn)
            if [[ "$CONTAINER_RUNTIME" == "docker" ]]; then
                $COMPOSE_CMD --profile host-vpn --profile docker up -d
            else
                $COMPOSE_CMD --profile host-vpn up -d
            fi
            ;;
        no-vpn)
            if [[ "$CONTAINER_RUNTIME" == "docker" ]]; then
                $COMPOSE_CMD --profile no-vpn --profile docker up -d
            else
                $COMPOSE_CMD --profile no-vpn up -d
            fi
            ;;
    esac
}

#######################################
# Initialize cache directories
#######################################
init_cache() {
    log "info" "Initializing cache directories..."
    
    mkdir -p "$CACHE_DIR/squid"
    mkdir -p "$CACHE_DIR/streaming"
    
    if [[ -d "$CACHE_DIR/squid" ]]; then
        chmod 755 "$CACHE_DIR/squid"
    fi
}

#######################################
# Show service status
#######################################
show_status() {
    echo ""
    echo "=========================================="
    echo "Proxy Service Status"
    echo "=========================================="
    
    local containers=("proxy-squid" "proxy-dante" "proxy-admin")
    
    if is_container_running "proxy-vpn"; then
        containers=("proxy-vpn" "${containers[@]}")
    fi
    
    for container in "${containers[@]}"; do
        if is_container_running "$container"; then
            local status
            status=$(get_container_status "$container")
            echo "  ✓ $container: $status"
        else
            echo "  ✗ $container: not running"
        fi
    done
    
    echo ""
    echo "Connection Information:"
    echo "  HTTP Proxy:  ${BIND_ADDRESS:-0.0.0.0}:${HTTP_PROXY_PORT:-3128}"
    echo "  SOCKS Proxy: ${BIND_ADDRESS:-0.0.0.0}:${SOCKS_PROXY_PORT:-1080}"
    echo "  Admin Panel: http://localhost:${PROXY_ADMIN_PORT:-8080}"
    
    echo ""
    get_cache_stats
    echo "=========================================="
}

#######################################
# Main function
#######################################
main() {
    local PULL="false"
    local FORCE_NO_VPN="false"
    local FORCE_HOST_VPN="false"
    local SHOW_STATUS="false"
    local DRY_RUN="false"
    local VERBOSE="false"
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                usage
                exit 0
                ;;
            -v|--verbose)
                VERBOSE="true"
                LOG_LEVEL="debug"
                shift
                ;;
            -p|--pull)
                PULL="true"
                shift
                ;;
            -n|--no-vpn)
                FORCE_NO_VPN="true"
                shift
                ;;
            --host-vpn)
                FORCE_HOST_VPN="true"
                shift
                ;;
            -s|--status)
                SHOW_STATUS="true"
                shift
                ;;
            -d|--dry-run)
                DRY_RUN="true"
                shift
                ;;
            *)
                log "error" "Unknown option: $1"
                usage
                exit 1
                ;;
        esac
    done
    
    export LOG_LEVEL
    
    log "info" "=========================================="
    log "info" "Starting Proxy Service"
    log "info" "=========================================="
    
    # Load environment
    load_environment
    
    # Initialize runtime
    if ! init_runtime; then
        exit 1
    fi
    
    log "info" "Container runtime: $CONTAINER_RUNTIME"
    
    # Determine profile
    local profile="no-vpn"
    
    if [[ "$FORCE_HOST_VPN" == "true" ]]; then
        profile="host-vpn"
        log "info" "Mode: Host network (uses host's VPN if active)"
    elif [[ "$FORCE_NO_VPN" == "true" ]]; then
        profile="no-vpn"
        log "info" "Mode: Standalone (no VPN)"
    elif [[ "${USE_VPN:-false}" == "true" ]]; then
        profile="vpn"
        log "info" "Mode: Containerized VPN"
    else
        profile="no-vpn"
        log "info" "Mode: Standalone (no VPN)"
    fi
    
    if [[ "$DRY_RUN" == "true" ]]; then
        log "info" "Dry run mode - no changes will be made"
        log "info" "Would start with profile: $profile"
        exit 0
    fi
    
    # Run initialization
    "$SCRIPT_DIR/init" --check || {
        log "error" "Initialization check failed. Run './init' first."
        exit 1
    }
    
    # Check if already running
    if ! check_running; then
        exit 1
    fi
    
    # Pull images if requested
    if [[ "$PULL" == "true" ]]; then
        pull_images
    fi
    
    # Initialize cache
    init_cache
    
    # Start services
    start_with_profile "$profile" || {
        log "error" "Failed to start services"
        exit 1
    }
    
    log "info" "=========================================="
    log "info" "Proxy Service Started Successfully"
    log "info" "=========================================="
    
    if [[ "$SHOW_STATUS" == "true" ]]; then
        sleep 3
        show_status
    fi
}

main "$@"
